{
  "expo": {
    "name": "Chroma",
    "slug": "chroma",
    "scheme": "chroma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#0f0c18"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#130f1e"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "it.mtre_consulting.chroma"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "expo": {
      "scheme": "chroma",
      "platforms": [
        "ios",
        "android"
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "31b20a19-95f9-4a2b-aa30-022858855c56"
      }
    }
  }
}
