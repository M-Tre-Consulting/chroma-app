<Window x:Class="Chroma.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chroma" Height="720" Width="1100"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar Navigation Column -->
            <ColumnDefinition Width="220" />
            <!-- Splitter Column -->
            <ColumnDefinition Width="Auto" />
            <!-- Main Content Workspace Column -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 1. LEFT SIDEBAR PANEL -->
        <Border Grid.Column="0" Background="{StaticResource BgSunkenBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="16,20,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo/Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Chroma" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Native Windows Port" FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Navigations Sidebar Sections -->
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="Workspace Pages" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="4,0,0,6"/>
                    <Button x:Name="BtnNavPalettes" Content="🎨  Palettes" Style="{StaticResource SidebarButtonStyle}" Click="BtnNav_Click" Tag="0"/>
                    <Button x:Name="BtnNavTokens" Content="📝  Tokens" Style="{StaticResource SidebarButtonStyle}" Click="BtnNav_Click" Tag="1"/>
                    <Button x:Name="BtnNavExport" Content="💾  Export" Style="{StaticResource SidebarButtonStyle}" Click="BtnNav_Click" Tag="2"/>
                </StackPanel>

                <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="{StaticResource BorderBrush}"/>

                <!-- App Info Footer -->
                <StackPanel Grid.Row="3" Margin="0,12,0,0">
                    <TextBlock Text="Status: Connected" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="WPF C# Native Core" FontSize="10" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Vertical Grid Splitter -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="1" Background="{StaticResource BorderBrush}"/>

        <!-- 2. MAIN APPLICATION CONTENT VIEWSTACK -->
        <TabControl x:Name="MainViewStack" Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
            <TabControl.Resources>
                <!-- Hides the default tab headers to act like an AdwViewStack / Stack view -->
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <!-- ========================================== -->
            <!-- VIEW 1: PALETTES PAGE                      -->
            <!-- ========================================== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Sidebar: Palettes List -->
                        <ColumnDefinition Width="220" />
                        <!-- Workspace Panel Splitter -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Workspace editor -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar Palettes -->
                    <Border Grid.Column="0" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="MY PALETTES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="4,6,0,8"/>

                            <!-- Palettes list box -->
                            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}">
                                <ListBoxItem HorizontalContentAlignment="Stretch" Margin="0,2">
                                    <Border CornerRadius="6" Background="{StaticResource AccentSoftBrush}" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="99" Background="#3584e4" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="Default Palette" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="5" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ListBoxItem>
                                <ListBoxItem HorizontalContentAlignment="Stretch" Margin="0,2">
                                    <Border CornerRadius="6" Background="Transparent" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="99" Background="#2ec27e" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="Material System" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="8" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ListBoxItem>
                            </ListBox>

                            <!-- Sidebar Footer: New Palette -->
                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="TxtNewPaletteName" Tag="New palette…"/>
                                <Button Grid.Column="1" Content="+" Style="{StaticResource ModernButtonStyle}" Width="32" Margin="6,0,0,0" Padding="0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="1" Background="{StaticResource BorderBrush}"/>

                    <!-- Main Palette Editor Workspace -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header area -->
                        <Border Grid.Row="0" Background="{StaticResource BgRaisedBrush}" Padding="16,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock Text="Default Palette" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="5 colours • Updated 2 hours ago" FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Workspace Split Columns -->
                        <Grid Grid.Row="1" Margin="16">
                            <Grid.ColumnDefinitions>
                                <!-- Color Selection area -->
                                <ColumnDefinition Width="260"/>
                                <!-- Color cards area -->
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: Color Picker & Swatches selection -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="COLOR SPECIFICATION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12"/>
                                
                                <!-- Modern Color representation block -->
                                <Border CornerRadius="8" Background="{StaticResource BgSunkenBrush}" Height="180" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Interactive Gradient picker representation -->
                                        <Border Grid.Row="0" CornerRadius="6">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FFA374F2" Offset="0"/>
                                                    <GradientStop Color="#FF3584E4" Offset="0.5"/>
                                                    <GradientStop Color="#FF2EC27E" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="Wheel / Color Spectrums" Foreground="#E0FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold"/>
                                        </Border>

                                        <!-- Live Color Selection preview bar -->
                                        <Border Grid.Row="1" CornerRadius="4" Height="24" Background="#FFA374F2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,12,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Text Entry Name -->
                                <TextBlock Text="Colour Name" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBox Margin="0,0,0,12" Text="Accent Purple"/>

                                <Button Content="Add to Palette" Style="{StaticResource AccentButtonStyle}" Height="36"/>
                            </StackPanel>

                            <!-- Column 2: Color list cards -->
                            <Grid Grid.Column="1" Margin="16,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="PALETTE COLOUR CARDS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12"/>

                                <!-- Cards scroll container -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="PaletteCardsStack">
                                        <!-- Color Card Item -->
                                        <Border CornerRadius="8" Background="{StaticResource BgRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8" Padding="12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- Row Header -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="6" Background="#A374F2" Width="28" Height="28" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Accent Purple" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="#A374F2" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    
                                                    <!-- WCAG badge -->
                                                    <Border Grid.Column="2" CornerRadius="12" Background="#222EC27E" Padding="10,4" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock Text="AAA PASS" Foreground="{StaticResource WcagAaaBrush}" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    
                                                    <!-- Trash action button -->
                                                    <Button Grid.Column="3" Content="🗑" Style="{StaticResource ModernButtonStyle}" Width="28" Height="28" Padding="0"/>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- Card Item 2 -->
                                        <Border CornerRadius="8" Background="{StaticResource BgRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8" Padding="12">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="6" Background="#FF3584E4" Width="28" Height="28" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="Theme Blue" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="#3584E4" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    
                                                    <Border Grid.Column="2" CornerRadius="12" Background="#223584E4" Padding="10,4" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <TextBlock Text="AA PASS" Foreground="{StaticResource WcagAaBrush}" FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    
                                                    <Button Grid.Column="3" Content="🗑" Style="{StaticResource ModernButtonStyle}" Width="28" Height="28" Padding="0"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ========================================== -->
            <!-- VIEW 2: TOKENS PAGE                        -->
            <!-- ========================================== -->
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Sidebar: Token Groups -->
                        <ColumnDefinition Width="220" />
                        <!-- Splitter -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Workspace editor -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar Groups -->
                    <Border Grid.Column="0" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="TOKEN GROUPS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="4,6,0,8"/>

                            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}">
                                <ListBoxItem HorizontalContentAlignment="Stretch" Margin="0,2">
                                    <Border CornerRadius="6" Background="{StaticResource AccentSoftBrush}" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Brand Guidelines" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="4" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ListBoxItem>
                                <ListBoxItem HorizontalContentAlignment="Stretch" Margin="0,2">
                                    <Border CornerRadius="6" Background="Transparent" Padding="8,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Application Backgrounds" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="3" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </ListBoxItem>
                            </ListBox>

                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Tag="New group…"/>
                                <Button Grid.Column="1" Content="+" Style="{StaticResource ModernButtonStyle}" Width="32" Margin="6,0,0,0" Padding="0"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="1" Background="{StaticResource BorderBrush}"/>

                    <!-- Main Workspace -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header row -->
                        <Border Grid.Row="0" Background="{StaticResource BgRaisedBrush}" Padding="16,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Brand Guidelines" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="Active Token mapping configurations" FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Remove Group" Style="{StaticResource ModernButtonStyle}" Foreground="{StaticResource WcagFailBrush}" Padding="12,6"/>
                            </Grid>
                        </Border>

                        <!-- Scrollable table of tokens -->
                        <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- Token Row Item -->
                                <Border CornerRadius="8" Background="{StaticResource BgRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Mapped color dot -->
                                        <Border Grid.Column="0" CornerRadius="6" Background="#A374F2" Width="20" Height="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="color-brand-primary" FontFamily="Consolas" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock Text="Primary accent brand color token" FontSize="11" Foreground="{StaticResource TextDimBrush}"/>
                                        </StackPanel>
                                        
                                        <!-- Palette color selection dropdown -->
                                        <ComboBox Grid.Column="2" SelectedIndex="0" VerticalAlignment="Center" Margin="0,0,16,0" Padding="8,4">
                                            <ComboBoxItem Content="Default Palette : Accent Purple"/>
                                            <ComboBoxItem Content="Material System : Light Green"/>
                                            <ComboBoxItem Content="— none —"/>
                                        </ComboBox>
                                        
                                        <Button Grid.Column="3" Content="🗑" Style="{StaticResource ModernButtonStyle}" Width="28" Height="28" Padding="0"/>
                                    </Grid>
                                </Border>

                                <!-- Token Row Item 2 -->
                                <Border CornerRadius="8" Background="{StaticResource BgRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8" Padding="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <Border Grid.Column="0" CornerRadius="6" Background="#FF3584E4" Width="20" Height="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="color-brand-secondary" FontFamily="Consolas" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock Text="Secondary system brand color token" FontSize="11" Foreground="{StaticResource TextDimBrush}"/>
                                        </StackPanel>
                                        
                                        <ComboBox Grid.Column="2" SelectedIndex="0" VerticalAlignment="Center" Margin="0,0,16,0" Padding="8,4">
                                            <ComboBoxItem Content="Default Palette : Theme Blue"/>
                                            <ComboBoxItem Content="Material System : Orange"/>
                                            <ComboBoxItem Content="— none —"/>
                                        </ComboBox>
                                        
                                        <Button Grid.Column="3" Content="🗑" Style="{StaticResource ModernButtonStyle}" Width="28" Height="28" Padding="0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer: Add token entry -->
                        <Border Grid.Row="2" Background="{StaticResource BgSunkenBrush}" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Tag="Token name…"/>
                                <Button Grid.Column="1" Content="Add Token" Style="{StaticResource AccentButtonStyle}" Width="120" Margin="12,0,0,0" Height="32"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ========================================== -->
            <!-- VIEW 3: EXPORT PAGE                        -->
            <!-- ========================================== -->
            <TabItem>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header switcher formatting -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Button Content="CSS Variables" Style="{StaticResource AccentButtonStyle}" Margin="4,0" Padding="14,6"/>
                        <Button Content="SCSS Variables" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6"/>
                        <Button Content="Style Dictionary" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6"/>
                        <Button Content="Tailwind TS" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6"/>
                        <Button Content="Android XML" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6"/>
                    </StackPanel>

                    <!-- Scrollable Monospace Read-Only preview -->
                    <Border Grid.Row="1" CornerRadius="8" Background="{StaticResource BgSunkenBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBox Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="13" Foreground="#B0B3C6" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="16">
                            <TextBox.Text>
:root {
  --color-brand-primary: #a374f2;
  --color-brand-secondary: #3584e4;
  --color-system-success: #2ec27e;
  --color-system-warning: #e6c000;
  --color-system-danger: #e01b24;
}
                            </TextBox.Text>
                        </TextBox>
                    </Border>

                    <!-- Copy / Save actions -->
                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Copy to Clipboard" Style="{StaticResource AccentButtonStyle}" Height="36" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Save as File…" Style="{StaticResource ModernButtonStyle}" Height="36" Margin="8,0,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
