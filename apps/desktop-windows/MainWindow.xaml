<Window x:Class="Chroma.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Chroma.Converters"
        Title="Chroma" Height="750" Width="1100"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen"
        Icon="/ic_launcher.png"
        FontFamily="Segoe UI">
    <Window.Resources>
        <conv:TokenToColorConverter x:Key="TokenToColorConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            
            <ColumnDefinition Width="220" />
            
            <ColumnDefinition Width="Auto" />
            
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        
        <Border Grid.Column="0" Background="{StaticResource BgSunkenBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid Margin="16,20,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="Chroma" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                </StackPanel>

                
                <StackPanel Grid.Row="1" Margin="0,0,0,16">
                    <TextBlock Text="Workspace Pages" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="4,0,0,6"/>
                    <Button x:Name="BtnNavPalettes" Content="🎨  Palettes" Style="{StaticResource SidebarButtonStyle}" Click="BtnNav_Click" Tag="0"/>
                    <Button x:Name="BtnNavTokens" Content="📝  Tokens" Style="{StaticResource SidebarButtonStyle}" Click="BtnNav_Click" Tag="1"/>
                    <Button x:Name="BtnNavExport" Content="💾  Export" Style="{StaticResource SidebarButtonStyle}" Click="BtnNav_Click" Tag="2"/>
                </StackPanel>

                <Separator Grid.Row="1" VerticalAlignment="Bottom" Background="{StaticResource BorderBrush}"/>
            </Grid>
        </Border>

        
        <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="1" Background="{StaticResource BorderBrush}"/>

        
        <TabControl x:Name="MainViewStack" Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
            <TabControl.Resources>
                
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            
            
            
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        
                        <ColumnDefinition Width="220" />
                        
                        <ColumnDefinition Width="Auto" />
                        
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    
                    <Border Grid.Column="0" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="MY PALETTES" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="4,6,0,8"/>

                            
                            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}"
                                     ItemsSource="{Binding Palettes}" SelectedItem="{Binding ActivePalette}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Style.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2260CDFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1560CDFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFF"/>
                                        </Style.Resources>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder" CornerRadius="6" Background="Transparent" Padding="8,6">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#0DFFFFFF"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="99" Background="{StaticResource AccentBrush}" Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Colours.Count}" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            
                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="TxtNewPaletteName" Padding="8,6"/>
                                <Button Grid.Column="1" Content="+" Style="{StaticResource ModernButtonStyle}" Width="32" Margin="6,0,0,0" Padding="0" Click="BtnAddPalette_Click"/>
                            </Grid>
                        </Grid>
                    </Border>

                    
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="1" Background="{StaticResource BorderBrush}"/>

                    
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        
                        <Border Grid.Row="0" Background="{StaticResource BgRaisedBrush}" Padding="16,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ActivePalette.Name, FallbackValue='No Palette Selected'}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="{Binding ActivePaletteColoursCountText}" FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Delete Palette" Style="{StaticResource DestructiveButtonStyle}" Padding="12,6" Click="BtnDeletePalette_Click"/>
                            </Grid>
                        </Border>

                        
                        <Grid Grid.Row="1" Margin="16">
                            <Grid.ColumnDefinitions>
                                
                                <ColumnDefinition Width="280"/>
                                
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="COLOR SPECIFICATION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12"/>
                                    
                                    <!-- Selected color swatch preview -->
                                    <Border CornerRadius="8" Height="40" Background="{Binding SelectedColorHex, FallbackValue='#7c6ff7'}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,12"/>

                                    <!-- Launch Picker Button -->
                                    <Button Content="🎨 Open Color Picker…" Style="{StaticResource ModernButtonStyle}" Margin="0,0,0,12" Height="32" Click="BtnPickNativeColor_Click"/>

                                    <!-- Color Name input -->
                                    <TextBlock Text="Colour Name" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Margin="0,0,0,12" Text="{Binding SelectedColorName, UpdateSourceTrigger=PropertyChanged}"/>

                                    <!-- Hex input -->
                                    <TextBlock Text="Hex Value (e.g. #7c6ff7)" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBox Margin="0,0,0,16" Text="{Binding SelectedColorHex, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas"/>

                                    <Button Content="Add to Palette" Style="{StaticResource AccentButtonStyle}" Height="36" Click="BtnAddColour_Click"/>
                                </StackPanel>
                            </ScrollViewer>

                            
                            <Grid Grid.Column="1" Margin="16,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="PALETTE COLOUR CARDS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,12"/>

                                
                                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}"
                                         ItemsSource="{Binding ActivePalette.Colours}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Background="{StaticResource BgRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8" Padding="6" HorizontalContentAlignment="Stretch">
                                                <Expander.Header>
                                                    <Grid HorizontalAlignment="Stretch" Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <Border Grid.Column="0" CornerRadius="6" Background="{Binding Hex}" Width="28" Height="28" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                                        
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                            <TextBlock Text="{Binding Hex}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontFamily="Consolas"/>
                                                        </StackPanel>
                                                        
                                                        <!-- Dynamic WCAG rating badge -->
                                                        <Border Grid.Column="2" CornerRadius="12" Padding="10,4" VerticalAlignment="Center" Margin="0,0,12,0" Background="{Binding WcagBadgeBrush}">
                                                            <TextBlock Text="{Binding WcagRating}" Foreground="{Binding WcagTextBrush}" FontSize="10" FontWeight="Bold"/>
                                                        </Border>
                                                        
                                                        <Button Grid.Column="3" Content="🗑" Style="{StaticResource ModernButtonStyle}" Width="28" Height="28" Padding="0" Click="BtnDeleteColour_Click" Tag="{Binding}"/>
                                                    </Grid>
                                                </Expander.Header>
                                                
                                                <!-- Contrast Audit Panel -->
                                                <Grid Margin="12,8,12,12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Contrast BG Custom Entry and Ratio -->
                                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="vs" VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}" Margin="0,0,8,0"/>
                                                        
                                                        <!-- Preview of contrast BG color -->
                                                        <Border Grid.Column="1" Width="16" Height="16" CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0" VerticalAlignment="Center" Background="{Binding ContrastBgHex, FallbackValue=#FFFFFF}"/>
                                                        
                                                        <TextBlock Grid.Column="2" Text="#" VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}" Margin="0,0,2,0"/>
                                                        <TextBox Grid.Column="3" Text="{Binding ContrastBgHex, UpdateSourceTrigger=PropertyChanged}" Padding="4,2" FontSize="11" FontFamily="Consolas" MaxLength="7"/>
                                                        
                                                        <TextBlock Grid.Column="4" Text="{Binding ContrastRatioText}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </Grid>

                                                    <!-- Test Text Preview -->
                                                    <Border Grid.Row="1" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8,6" Margin="0,0,0,10" Background="{Binding ContrastBgHex, FallbackValue=#FFFFFF}">
                                                        <TextBlock Text="The quick brown fox" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{Binding Hex, FallbackValue=#000000}"/>
                                                    </Border>

                                                    <!-- Suggested Fix Section -->
                                                    <Grid Grid.Row="2" Visibility="{Binding IsContrastFail, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="Suggested Fix:" VerticalAlignment="Center" Foreground="{StaticResource TextDimBrush}" Margin="0,0,8,0" FontSize="11"/>
                                                        <Border Grid.Column="1" Width="14" Height="14" CornerRadius="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,6,0" VerticalAlignment="Center" Background="{Binding SuggestedFixHex, FallbackValue=#FFFFFF}"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding SuggestedFixHex}" FontFamily="Consolas" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="3" Content="Apply" Style="{StaticResource AccentButtonStyle}" Height="22" Padding="8,0" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnApplyContrastFix_Click" Tag="{Binding}"/>
                                                    </Grid>
                                                </Grid>
                                            </Expander>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            
            
            
            <TabItem>
                <Grid>
                    <Grid.ColumnDefinitions>
                        
                        <ColumnDefinition Width="220" />
                        
                        <ColumnDefinition Width="Auto" />
                        
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    
                    <Border Grid.Column="0" Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="TOKEN GROUPS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextDimBrush}" Margin="4,6,0,8"/>

                            
                            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}"
                                     ItemsSource="{Binding TokenGroups}" SelectedItem="{Binding ActiveTokenGroup}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Style.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2260CDFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#1560CDFF"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFF"/>
                                        </Style.Resources>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder" CornerRadius="6" Background="Transparent" Padding="8,6">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#0DFFFFFF"/>
                                                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Tokens.Count}" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="TxtNewGroupName" Padding="8,6"/>
                                <Button Grid.Column="1" Content="+" Style="{StaticResource ModernButtonStyle}" Width="32" Margin="6,0,0,0" Padding="0" Click="BtnAddTokenGroup_Click"/>
                            </Grid>
                        </Grid>
                    </Border>

                    
                    <GridSplitter Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Stretch" Width="1" Background="{StaticResource BorderBrush}"/>

                    
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        
                        <Border Grid.Row="0" Background="{StaticResource BgRaisedBrush}" Padding="16,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ActiveTokenGroup.Name, FallbackValue='No Token Group'}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="Active Token mapping configurations" FontSize="11" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Remove Group" Style="{StaticResource DestructiveButtonStyle}" Padding="12,6" Click="BtnDeleteTokenGroup_Click"/>
                            </Grid>
                        </Border>

                        
                        <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" Margin="16"
                                 ItemsSource="{Binding ActiveTokenGroup.Tokens}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Background="{StaticResource BgRaisedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Color dot dynamically resolved via converter -->
                                            <Border Grid.Column="0" CornerRadius="6" Background="{Binding Converter={StaticResource TokenToColorConverter}}" Width="20" Height="20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{StaticResource TextDimBrush}"/>
                                            </StackPanel>
                                            
                                            <!-- ComboBox mapping selector -->
                                            <ComboBox Grid.Column="2" SelectedValuePath="ValueKey" DisplayMemberPath="DisplayName"
                                                      ItemsSource="{Binding DataContext.MappingOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedValue="{Binding ValueKey, Mode=TwoWay}"
                                                      SelectionChanged="CboTokenColor_SelectionChanged"
                                                      Tag="{Binding}"
                                                      VerticalAlignment="Center" Width="200" Padding="8,4"
                                                      Background="{StaticResource BgSunkenBrush}" Foreground="{StaticResource TextBrush}"
                                                      BorderBrush="{StaticResource BorderBrush}"/>
                                            
                                            <Button Grid.Column="3" Content="🗑" Style="{StaticResource ModernButtonStyle}" Width="28" Height="28" Padding="0" Click="BtnDeleteToken_Click" Tag="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        
                        <Border Grid.Row="2" Background="{StaticResource BgSunkenBrush}" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" x:Name="TxtNewTokenName" Padding="8,6"/>
                                <TextBox Grid.Column="1" x:Name="TxtNewTokenDesc" Margin="12,0,0,0" Padding="8,6"/>
                                <Button Grid.Column="2" Content="Add Token" Style="{StaticResource AccentButtonStyle}" Width="120" Margin="12,0,0,0" Height="32" Click="BtnAddToken_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            
            
            
            <TabItem>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Button Content="CSS Variables" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6" Click="BtnExportFormat_Click" Tag="css"/>
                        <Button Content="SCSS Variables" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6" Click="BtnExportFormat_Click" Tag="scss"/>
                        <Button Content="Style Dictionary" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6" Click="BtnExportFormat_Click" Tag="json"/>
                        <Button Content="Tailwind TS" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6" Click="BtnExportFormat_Click" Tag="tailwind"/>
                        <Button Content="Android XML" Style="{StaticResource ModernButtonStyle}" Margin="4,0" Padding="14,6" Click="BtnExportFormat_Click" Tag="android"/>
                    </StackPanel>

                    
                    <Border Grid.Row="1" CornerRadius="8" Background="{StaticResource BgSunkenBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBox Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="13" Foreground="#B0B3C6" IsReadOnly="True" AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="16"
                                 Text="{Binding ExportPreviewText, Mode=OneWay}"/>
                    </Border>

                    
                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Copy to Clipboard" Style="{StaticResource AccentButtonStyle}" Height="36" Margin="0,0,8,0" Click="BtnCopyClipboard_Click"/>
                        <Button Grid.Column="1" Content="Save as File…" Style="{StaticResource ModernButtonStyle}" Height="36" Margin="8,0,0,0" Click="BtnSaveFile_Click"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

